# ---- Database ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_dev?schema=public"

# ---- JWT ----
JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_TTL="7d"

# ---- API ----
API_PORT=3001
API_PREFIX="/api/v1"
CORS_ORIGIN="http://localhost:3000"

# ---- Web (Next.js public) ----
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/api/v1"

# ---- Uploads ----
UPLOAD_DRIVER="local"        # local | s3
UPLOAD_LOCAL_DIR="./uploads"
UPLOAD_MAX_MB=10

# S3-compatible (chỉ dùng khi UPLOAD_DRIVER=s3)
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_BASE_URL=""

# ---- Seed admin ----
SEED_ADMIN_EMAIL="admin@hotel.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
