// Prisma schema for Hotel Management API.
// Full entity set lives in PLAN.md (Section 2). Phase 1 ships User + Setting + AuditLog;
// later phases add Room, Customer, Booking, BookingItem, Payment, Service, PricePackage,
// HousekeepingTask, FinanceTx, Staff, Payroll, Upload, Category.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String
  role         UserRole   @default(RECEPTIONIST)
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  auditLogs AuditLog[]

  @@index([role, status])
}

// Single-row table for property settings. Enforced by checking `id = "singleton"` at the service layer.
model Setting {
  id              String   @id @default("singleton")
  propertyName    String
  taxCode         String?
  address         String?
  email           String?
  website         String?
  hotline         String?
  themeTone       Int      @default(2) // 1 Pink Boutique | 2 Boutique Vibe | 3 Olive Organic
  monthlyRevenueTarget Decimal? @db.Decimal(15, 2)
  note            String?
  updatedAt       DateTime @updatedAt
}

enum CategoryGroup {
  ROOM_TYPE
  ROOM_AREA
  ROOM_STATUS
  CLEANING_STATUS
  PRICE_TYPE
  PAYMENT_METHOD
  BOOKING_SOURCE
  BOOKING_STATUS
  HOUSEKEEPING_TASK_STATUS
  FINANCE_GROUP
  GUEST_SOURCE
  UNIT
  SERVICE_GROUP
  SURCHARGE_TYPE
}

model Category {
  id        String        @id @default(cuid())
  group     CategoryGroup
  code      String
  name      String
  sortOrder Int           @default(0)
  active    Boolean       @default(true)
  meta      Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  roomsAsType     Room[] @relation("RoomType")
  roomsAsArea     Room[] @relation("RoomArea")
  roomsAsStatus   Room[] @relation("RoomStatus")
  roomsAsCleaning Room[] @relation("RoomCleaningStatus")

  customers Customer[] @relation("CustomerSource")

  servicesAsGroup Service[] @relation("ServiceGroup")
  servicesAsUnit  Service[] @relation("ServiceUnit")

  @@unique([group, code])
  @@index([group, active, sortOrder])
}

model Room {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  typeId           String
  type             Category  @relation("RoomType", fields: [typeId], references: [id])
  areaId           String?
  area             Category? @relation("RoomArea", fields: [areaId], references: [id])
  capacity         Int       @default(2)
  basePrice        Decimal   @db.Decimal(15, 2)
  weekendPrice     Decimal?  @db.Decimal(15, 2)
  holidayPrice     Decimal?  @db.Decimal(15, 2)
  statusId         String
  status           Category  @relation("RoomStatus", fields: [statusId], references: [id])
  cleaningStatusId String
  cleaningStatus   Category  @relation("RoomCleaningStatus", fields: [cleaningStatusId], references: [id])
  defaultCheckIn   String?
  defaultCheckOut  String?
  images           String[]  @default([])
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([typeId])
  @@index([statusId])
  @@index([deletedAt])
}

model Customer {
  id          String    @id @default(cuid())
  code        String    @unique
  fullName    String
  phone       String?   @unique
  idNumber    String?   @unique
  email       String?
  address     String?
  nationality String?
  sourceId    String?
  source      Category? @relation("CustomerSource", fields: [sourceId], references: [id])
  note        String?
  docs        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([sourceId])
  @@index([deletedAt])
  @@index([fullName])
}

model Service {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  groupId   String
  group     Category  @relation("ServiceGroup", fields: [groupId], references: [id])
  unitId    String
  unit      Category  @relation("ServiceUnit", fields: [unitId], references: [id])
  price     Decimal   @db.Decimal(15, 2)
  active    Boolean   @default(true)
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([groupId])
  @@index([deletedAt])
}

model PricePackage {
  id         String    @id @default(cuid())
  code       String    @unique
  name       String
  applyType  String
  numNights  Int
  numGuests  Int
  totalPrice Decimal   @db.Decimal(15, 2)
  validFrom  DateTime  @db.Date
  validTo    DateTime  @db.Date
  detail     String?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([deletedAt])
  @@index([validFrom, validTo])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // create | update | delete
  entity    String   // e.g. booking, room
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}
