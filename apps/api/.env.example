# ─── NestJS API (apps/api) ───────────────────────────────────────────────────

# Database (Postgres). Railway: dùng biến `DATABASE_URL` plugin tự inject.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_dev?schema=public"

# JWT — ĐỔI sang chuỗi random ≥ 32 ký tự khi deploy production.
JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_TTL="7d"

# Server
# Local: API_PORT=3001. Railway tự inject PORT, app sẽ ưu tiên PORT.
API_PORT=3001
API_PREFIX="/api/v1"

# CORS — danh sách origin cách nhau bằng dấu phẩy.
# Production: điền domain Vercel (vd: https://hotel-web.vercel.app)
CORS_ORIGIN="http://localhost:3000"

# Uploads
UPLOAD_DRIVER="local"
UPLOAD_LOCAL_DIR="./uploads"
UPLOAD_MAX_MB=10

# S3-compatible (chỉ dùng khi UPLOAD_DRIVER=s3 — production nên dùng S3)
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_BASE_URL=""

# Seed admin (chỉ chạy lần đầu)
SEED_ADMIN_EMAIL="admin@hotel.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
