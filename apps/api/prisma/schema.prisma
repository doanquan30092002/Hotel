// Prisma schema for Hotel Management API.
// Full entity set lives in PLAN.md (Section 2). Phase 1 ships User + Setting + AuditLog;
// later phases add Room, Customer, Booking, BookingItem, Payment, Service, PricePackage,
// HousekeepingTask, FinanceTx, Staff, Payroll, Upload, Category.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String
  role         UserRole   @default(RECEPTIONIST)
  status       UserStatus @default(ACTIVE)
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  auditLogs AuditLog[]

  @@index([role, status])
}

// Single-row table for property settings. Enforced by checking `id = "singleton"` at the service layer.
model Setting {
  id              String   @id @default("singleton")
  propertyName    String
  taxCode         String?
  address         String?
  email           String?
  website         String?
  hotline         String?
  themeTone       Int      @default(2) // 1 Pink Boutique | 2 Boutique Vibe | 3 Olive Organic
  monthlyRevenueTarget Decimal? @db.Decimal(15, 2)
  note            String?
  updatedAt       DateTime @updatedAt
}

enum CategoryGroup {
  ROOM_TYPE
  ROOM_AREA
  ROOM_STATUS
  CLEANING_STATUS
  PRICE_TYPE
  PAYMENT_METHOD
  BOOKING_SOURCE
  BOOKING_STATUS
  HOUSEKEEPING_TASK_STATUS
  FINANCE_GROUP
  GUEST_SOURCE
  UNIT
  SERVICE_GROUP
  SURCHARGE_TYPE
}

model Category {
  id        String        @id @default(cuid())
  group     CategoryGroup
  code      String
  name      String
  sortOrder Int           @default(0)
  active    Boolean       @default(true)
  meta      Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  roomsAsType     Room[] @relation("RoomType")
  roomsAsArea     Room[] @relation("RoomArea")
  roomsAsStatus   Room[] @relation("RoomStatus")
  roomsAsCleaning Room[] @relation("RoomCleaningStatus")

  customers Customer[] @relation("CustomerSource")

  servicesAsGroup Service[] @relation("ServiceGroup")
  servicesAsUnit  Service[] @relation("ServiceUnit")

  bookingsAsSource    Booking[]     @relation("BookingSource")
  bookingsAsStatus    Booking[]     @relation("BookingStatus")
  bookingsAsPriceType Booking[]     @relation("BookingPriceType")
  bookingItemsAsSurchargeType BookingItem[] @relation("BookingItemSurchargeType")
  paymentsAsMethod    Payment[]     @relation("PaymentMethod")

  @@unique([group, code])
  @@index([group, active, sortOrder])
}

model Room {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  typeId           String
  type             Category  @relation("RoomType", fields: [typeId], references: [id])
  areaId           String?
  area             Category? @relation("RoomArea", fields: [areaId], references: [id])
  capacity         Int       @default(2)
  basePrice        Decimal   @db.Decimal(15, 2)
  weekendPrice     Decimal?  @db.Decimal(15, 2)
  holidayPrice     Decimal?  @db.Decimal(15, 2)
  statusId         String
  status           Category  @relation("RoomStatus", fields: [statusId], references: [id])
  cleaningStatusId String
  cleaningStatus   Category  @relation("RoomCleaningStatus", fields: [cleaningStatusId], references: [id])
  defaultCheckIn   String?
  defaultCheckOut  String?
  images           String[]  @default([])
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  bookingItems BookingItem[]

  @@index([typeId])
  @@index([statusId])
  @@index([deletedAt])
}

model Customer {
  id          String    @id @default(cuid())
  code        String    @unique
  fullName    String
  phone       String?   @unique
  idNumber    String?   @unique
  email       String?
  address     String?
  nationality String?
  sourceId    String?
  source      Category? @relation("CustomerSource", fields: [sourceId], references: [id])
  note        String?
  docs        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  bookings Booking[]

  @@index([sourceId])
  @@index([deletedAt])
  @@index([fullName])
}

model Service {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  groupId   String
  group     Category  @relation("ServiceGroup", fields: [groupId], references: [id])
  unitId    String
  unit      Category  @relation("ServiceUnit", fields: [unitId], references: [id])
  price     Decimal   @db.Decimal(15, 2)
  active    Boolean   @default(true)
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookingItems BookingItem[]

  @@index([groupId])
  @@index([deletedAt])
}

model PricePackage {
  id         String    @id @default(cuid())
  code       String    @unique
  name       String
  applyType  String
  numNights  Int
  numGuests  Int
  totalPrice Decimal   @db.Decimal(15, 2)
  validFrom  DateTime  @db.Date
  validTo    DateTime  @db.Date
  detail     String?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  bookings Booking[]

  @@index([deletedAt])
  @@index([validFrom, validTo])
}

enum BookingItemKind {
  ROOM
  SERVICE
  SURCHARGE
  DISCOUNT
}

model Booking {
  id              String        @id @default(cuid())
  code            String        @unique
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  sourceId        String?
  source          Category?     @relation("BookingSource", fields: [sourceId], references: [id])
  statusId        String
  status          Category      @relation("BookingStatus", fields: [statusId], references: [id])
  priceTypeId     String?
  priceType       Category?     @relation("BookingPriceType", fields: [priceTypeId], references: [id])
  packageId       String?
  package         PricePackage? @relation(fields: [packageId], references: [id])
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  checkInTime     String?
  checkOutTime    String?
  adults          Int           @default(1)
  children        Int           @default(0)
  numRooms        Int           @default(1)
  totalAmount     Decimal       @default(0) @db.Decimal(15, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(15, 2)
  remainingAmount Decimal       @default(0) @db.Decimal(15, 2)
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  items    BookingItem[]
  payments Payment[]

  @@index([statusId])
  @@index([customerId])
  @@index([checkIn, checkOut])
  @@index([deletedAt])
}

model BookingItem {
  id              String          @id @default(cuid())
  bookingId       String
  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind            BookingItemKind
  roomId          String?
  room            Room?           @relation(fields: [roomId], references: [id])
  serviceId       String?
  service         Service?        @relation(fields: [serviceId], references: [id])
  surchargeTypeId String?
  surchargeType   Category?       @relation("BookingItemSurchargeType", fields: [surchargeTypeId], references: [id])
  refCode         String?
  refName         String?
  quantity        Decimal         @default(1) @db.Decimal(10, 2)
  unitPrice       Decimal         @db.Decimal(15, 2)
  amount          Decimal         @db.Decimal(15, 2)
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([bookingId])
  @@index([roomId])
}

model Payment {
  id        String    @id @default(cuid())
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  methodId  String
  method    Category  @relation("PaymentMethod", fields: [methodId], references: [id])
  amount    Decimal   @db.Decimal(15, 2)
  paidAt    DateTime  @default(now())
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([bookingId])
  @@index([deletedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // create | update | delete
  entity    String   // e.g. booking, room
  entityId  String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}
