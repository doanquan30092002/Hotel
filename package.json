{
  "name": "hotel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @hotel/api --filter @hotel/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "api:dev": "pnpm --filter @hotel/api dev",
    "api:build": "pnpm --filter @hotel/api build",
    "api:lint": "pnpm --filter @hotel/api lint",
    "api:typecheck": "pnpm --filter @hotel/api typecheck",
    "api:test": "pnpm --filter @hotel/api test",
    "api:test:e2e": "pnpm --filter @hotel/api test:e2e",
    "api:prisma:migrate": "pnpm --filter @hotel/api prisma:migrate",
    "api:prisma:studio": "pnpm --filter @hotel/api prisma:studio",
    "api:prisma:seed": "pnpm --filter @hotel/api prisma:seed",
    "web:dev": "pnpm --filter @hotel/web dev",
    "web:build": "pnpm --filter @hotel/web build",
    "web:lint": "pnpm --filter @hotel/web lint",
    "web:typecheck": "pnpm --filter @hotel/web typecheck",
    "web:test": "pnpm --filter @hotel/web test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
